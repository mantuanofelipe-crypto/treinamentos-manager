@page
@model TreinamentosManager.Pages.Clientes.CreateModel
@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="card shadow-sm">
    <div class="card-header-dk d-flex align-items-center gap-2">
        <i class="fas fa-user-plus"></i>
        <h5 class="mb-0">Adicionar Cliente</h5>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Cliente.Nome" class="form-label form-label-dk"></label>
                    <input asp-for="Cliente.Nome" class="form-control" placeholder="Nome completo" />
                    <span asp-validation-for="Cliente.Nome" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Cliente.Email" class="form-label form-label-dk"></label>
                    <input asp-for="Cliente.Email" class="form-control" type="email" placeholder="email@empresa.com" />
                    <span asp-validation-for="Cliente.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Cliente.Telefone" class="form-label form-label-dk"></label>
                    <input asp-for="Cliente.Telefone" class="form-control" placeholder="(21) 99999-9999" />
                    <span asp-validation-for="Cliente.Telefone" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Cliente.Empresa" class="form-label form-label-dk"></label>
                    <input asp-for="Cliente.Empresa" class="form-control" placeholder="Nome da empresa" />
                    <span asp-validation-for="Cliente.Empresa" class="text-danger small"></span>
                </div>
            </div>
            <div class="section-divider"></div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dk-primary btn-lg px-4">
                    <i class="fas fa-save me-1"></i> Salvar Cliente
                </button>
                <a asp-page="Index" class="btn btn-dk-secondary btn-lg px-4">
                    <i class="fas fa-arrow-left me-1"></i> Voltar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
