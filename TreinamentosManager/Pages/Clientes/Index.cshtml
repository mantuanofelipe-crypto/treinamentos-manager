@page
@model TreinamentosManager.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="card shadow-sm">
    <div class="card-header-dk d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-building me-2"></i>Empresas Clientes</h5>
        <a asp-page="Create" class="btn btn-dk-primary btn-sm px-3">
            <i class="fas fa-plus me-1"></i> Nova Empresa
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Empresa</th>
                        <th>Email</th>
                        <th>CNPJ</th>
                        <th class="text-center">Total Alunos</th>
                        <th class="text-center">Futuras</th>
                        <th class="text-center">Ativas</th>
                        <th class="text-center">Finalizadas</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Clientes)
                    {
                        var now = DateTime.Now;
                        <tr class="@(!item.Ativo ? "table-secondary text-muted" : "")">
                            <td>
                                @if (item.Ativo)
                                { <span class="badge bg-success">Ativo</span> }
                                else
                                { <span class="badge bg-secondary">Inativo</span> }
                            </td>
                            <td class="fw-500">@item.Nome</td>
                            <td>@item.Email</td>
                            <td>@item.Empresa</td>
                            <td class="text-center">@(item.TotalAlunos?.ToString() ?? "—")</td>
                            <td class="text-center">
                                <span class="badge bg-primary">@item.Turmas.Count(t => t.Inicio > now)</span>
                            </td>
                            <td class="text-center">
                                <span class="badge" style="background:#D79A00">@item.Turmas.Count(t => t.Inicio <= now && t.Fim >= now)</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success">@item.Turmas.Count(t => t.Fim < now)</span>
                            </td>
                            <td class="text-center">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Detalhes">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Excluir">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Clientes.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>Nenhuma empresa cadastrada ainda.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
