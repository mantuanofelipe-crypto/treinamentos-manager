@page
@model TreinamentosManager.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="card shadow-sm">
    <div class="card-header-dk d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-building me-2"></i>Gerenciar Clientes</h5>
        <a asp-page="Create" class="btn btn-dk-primary btn-sm px-3">
            <i class="fas fa-plus me-1"></i> Novo Cliente
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Empresa</th>
                        <th>Telefone</th>
                        <th class="text-center">Turmas Ativas</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Clientes)
                    {
                        <tr>
                            <td class="fw-500">@Html.DisplayFor(m => item.Nome)</td>
                            <td>@Html.DisplayFor(m => item.Email)</td>
                            <td>@Html.DisplayFor(m => item.Empresa)</td>
                            <td>@Html.DisplayFor(m => item.Telefone)</td>
                            <td class="text-center">
                                <span class="badge" style="background:#D79A00">@item.Turmas.Count(t => t.Fim > DateTime.Now)</span>
                            </td>
                            <td class="text-center">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Detalhes">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Excluir">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Clientes.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>Nenhum cliente cadastrado ainda.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
