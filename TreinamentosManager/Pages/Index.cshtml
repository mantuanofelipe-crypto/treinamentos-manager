@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="hero-banner mb-4">
    <h1 class="fw-bold mb-1"><span>DESK</span> CLASS</h1>
    <p class="mb-0 opacity-75">Sistema de Gerenciamento de Treinamentos — DeskGraphics Consulting</p>
</div>

<!-- Estatísticas de turmas -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-concluida shadow-sm">
            <div class="fs-1 fw-bold">@Model.TurmasAtivas</div>
            <div class="opacity-90"><i class="fas fa-check-circle me-1"></i>Turmas Concluídas</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-andamento shadow-sm">
            <div class="fs-1 fw-bold">@Model.TurmasEmAndamento</div>
            <div class="opacity-90"><i class="fas fa-spinner me-1"></i>Em Andamento</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-futura shadow-sm">
            <div class="fs-1 fw-bold">@Model.TurmasFuturas</div>
            <div class="opacity-90"><i class="fas fa-calendar-alt me-1"></i>Agendadas</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-total shadow-sm">
            <div class="fs-1 fw-bold">@Model.TotalClientes</div>
            <div class="opacity-90"><i class="fas fa-building me-1"></i>Total Clientes</div>
        </div>
    </div>
</div>

<!-- Previsão de alocação -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100 border-0" style="border-left: 4px solid #D79A00 !important;">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:2.5rem;color:#D79A00"><i class="fas fa-hourglass-half"></i></div>
                    <div>
                        <div class="text-muted small">Previsão de Alocação Atual</div>
                        <div class="fs-2 fw-bold">@Model.PrevisaoAtual<span class="fs-6 fw-normal text-muted ms-1">horas</span></div>
                        <div class="text-muted small">Turmas que encerram em @DateTime.Now.ToString("MMMM/yyyy")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100 border-0" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:2.5rem;color:#0d6efd"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <div class="text-muted small">Previsão de Alocação Futura</div>
                        <div class="fs-2 fw-bold">@Model.PrevisaoFutura<span class="fs-6 fw-normal text-muted ms-1">horas</span></div>
                        <div class="text-muted small">Turmas que encerram em @DateTime.Now.AddMonths(1).ToString("MMMM/yyyy")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráfico evolutivo -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h6 class="fw-bold mb-3"><i class="fas fa-chart-area me-2" style="color:#D79A00"></i>Evolução da Carga Horária por Mês</h6>
        <canvas id="graficoAlocacao" height="100"></canvas>
    </div>
</div>

<!-- Acesso rápido -->
<div class="row g-3">
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="fas fa-chalkboard-teacher fa-3x mb-3" style="color:#D79A00"></i>
                <h5 class="fw-bold">Turmas</h5>
                <p class="text-muted small">Gerencie as turmas de treinamento, datas e instrutores.</p>
                <a href="/Turmas" class="btn btn-dk-primary w-100">
                    <i class="fas fa-list me-1"></i> Gerenciar Turmas
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="fas fa-user-tie fa-3x mb-3" style="color:#5A5A5A"></i>
                <h5 class="fw-bold">Instrutores</h5>
                <p class="text-muted small">Cadastre e gerencie os instrutores responsáveis.</p>
                <a href="/Instrutores" class="btn btn-dk-secondary w-100">
                    <i class="fas fa-users-cog me-1"></i> Gerenciar Instrutores
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="fas fa-building fa-3x mb-3" style="color:#D79A00"></i>
                <h5 class="fw-bold">Clientes</h5>
                <p class="text-muted small">Gerencie a base de clientes participantes.</p>
                <a href="/Clientes" class="btn btn-dk-primary w-100">
                    <i class="fas fa-users me-1"></i> Gerenciar Clientes
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="fas fa-cogs fa-3x mb-3" style="color:#5A5A5A"></i>
                <h5 class="fw-bold">Softwares</h5>
                <p class="text-muted small">Cadastre os softwares disponíveis para treinamentos.</p>
                <a href="/Softwares" class="btn btn-dk-secondary w-100">
                    <i class="fas fa-tools me-1"></i> Gerenciar Softwares
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoLabels));
    const historico = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoHistorico));
    const tendencia = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoTendencia));

    new Chart(document.getElementById('graficoAlocacao'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    label: 'Carga Horária (horas)',
                    data: historico.map((v, i) => tendencia[i] === null ? v : null),
                    borderColor: '#D79A00',
                    backgroundColor: 'rgba(215,154,0,0.1)',
                    fill: true,
                    tension: 0.3,
                    pointRadius: 4,
                    spanGaps: true
                },
                {
                    label: 'Tendência Futura',
                    data: tendencia,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13,110,253,0.05)',
                    borderDash: [6, 4],
                    fill: false,
                    tension: 0.3,
                    pointRadius: 4,
                    spanGaps: true
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'top' },
                tooltip: { mode: 'index', intersect: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    title: { display: true, text: 'Horas' }
                }
            }
        }
    });
</script>
}
