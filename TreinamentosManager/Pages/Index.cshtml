@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="hero-banner mb-3">
    <h1 class="fw-bold mb-1"><span>DESK</span> CLASS</h1>
    <p class="mb-0 opacity-75">Sistema de Gerenciamento de Treinamentos — DeskGraphics Consulting</p>
</div>

<!-- Estatísticas de turmas -->
<div class="row g-2 mb-3">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-concluida shadow-sm py-2">
            <div class="fs-3 fw-bold">@Model.TurmasAtivas</div>
            <div class="opacity-90 small"><i class="fas fa-check-circle me-1"></i>Turmas Concluídas</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-andamento shadow-sm py-2">
            <div class="fs-3 fw-bold">@Model.TurmasEmAndamento</div>
            <div class="opacity-90 small"><i class="fas fa-spinner me-1"></i>Em Andamento</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-futura shadow-sm py-2">
            <div class="fs-3 fw-bold">@Model.TurmasFuturas</div>
            <div class="opacity-90 small"><i class="fas fa-calendar-alt me-1"></i>Agendadas</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-card-total shadow-sm py-2">
            <div class="fs-3 fw-bold">@Model.TotalClientes</div>
            <div class="opacity-90 small"><i class="fas fa-building me-1"></i>Total Clientes</div>
        </div>
    </div>
</div>

<!-- Previsão de alocação -->
<div class="row g-2 mb-3">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 py-1" style="border-left: 4px solid #D79A00 !important;">
            <div class="card-body py-2">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:1.8rem;color:#D79A00"><i class="fas fa-hourglass-half"></i></div>
                    <div>
                        <div class="text-muted small">Previsão de Alocação Atual</div>
                        <div class="fs-4 fw-bold">@Model.PrevisaoAtual<span class="fs-6 fw-normal text-muted ms-1">horas</span></div>
                        <div class="text-muted" style="font-size:0.75rem">Turmas que encerram em @DateTime.Now.ToString("MMMM/yyyy")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0 py-1" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body py-2">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:1.8rem;color:#0d6efd"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <div class="text-muted small">Previsão de Alocação Futura</div>
                        <div class="fs-4 fw-bold">@Model.PrevisaoFutura<span class="fs-6 fw-normal text-muted ms-1">horas</span></div>
                        <div class="text-muted" style="font-size:0.75rem">Turmas que encerram em @DateTime.Now.AddMonths(1).ToString("MMMM/yyyy")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráfico evolutivo -->
<div class="shadow-sm rounded p-3 bg-white">
    <h6 class="fw-bold mb-2"><i class="fas fa-chart-area me-2" style="color:#D79A00"></i>Evolução da Carga Horária por Mês</h6>
    <div class="mb-2">
        <div class="btn-group btn-group-sm" role="group" id="filtroModalidade">
            <button type="button" class="btn btn-outline-secondary active" data-modalidade="todos">Todos</button>
            <button type="button" class="btn btn-outline-secondary" data-modalidade="Presencial">Presencial</button>
            <button type="button" class="btn btn-outline-secondary" data-modalidade="Online">Online</button>
        </div>
    </div>
    <canvas id="graficoAlocacao"></canvas>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoLabels));
    const dados = {
        todos:      { hist: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoHistorico)),      tend: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoTendencia)) },
        Presencial: { hist: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoPresencial)),     tend: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoPresencialTendencia)) },
        Online:     { hist: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoOnline)),         tend: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoOnlineTendencia)) }
    };

    const ctx = document.getElementById('graficoAlocacao');
    const chart = new Chart(ctx, {
        type: 'line',
        data: { labels, datasets: buildDatasets('todos') },
        options: {
            responsive: true,
            aspectRatio: 4,
            plugins: { legend: { position: 'top' }, tooltip: { mode: 'index', intersect: false } },
            scales: { y: { beginAtZero: true, title: { display: true, text: 'Horas' } } }
        }
    });

    function buildDatasets(modalidade) {
        const d = dados[modalidade];
        return [
            {
                label: 'Carga Horária',
                data: d.hist.map((v, i) => d.tend[i] !== null ? null : v),
                borderColor: '#D79A00', backgroundColor: 'rgba(215,154,0,0.1)',
                fill: true, tension: 0.3, pointRadius: 4, spanGaps: true
            },
            {
                label: 'Tendência Futura',
                data: d.tend,
                borderColor: '#0d6efd', backgroundColor: 'rgba(13,110,253,0.05)',
                borderDash: [6, 4], fill: false, tension: 0.3, pointRadius: 4, spanGaps: true
            }
        ];
    }

    document.querySelectorAll('#filtroModalidade button').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('#filtroModalidade button').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            chart.data.datasets = buildDatasets(this.dataset.modalidade);
            chart.update();
        });
    });
</script>
}
