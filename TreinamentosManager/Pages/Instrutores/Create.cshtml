@page
@model TreinamentosManager.Pages.Instrutores.CreateModel
@{
    ViewData["Title"] = "Adicionar Instrutor";
}

<div class="card shadow-sm">
    <div class="card-header-dk d-flex align-items-center gap-2">
        <i class="fas fa-user-plus"></i>
        <h5 class="mb-0">Adicionar Instrutor</h5>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Instrutor.Nome" class="form-label form-label-dk"></label>
                    <input asp-for="Instrutor.Nome" class="form-control" />
                    <span asp-validation-for="Instrutor.Nome" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Instrutor.Email" class="form-label form-label-dk"></label>
                    <input asp-for="Instrutor.Email" class="form-control" type="email" />
                    <span asp-validation-for="Instrutor.Email" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input type="hidden" name="Instrutor.Ativo" value="false" />
                        <input asp-for="Instrutor.Ativo" class="form-check-input" type="checkbox" checked />
                        <label asp-for="Instrutor.Ativo" class="form-check-label">Instrutor ativo</label>
                    </div>
                </div>
            </div>
            <div class="section-divider"></div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dk-primary btn-lg px-4">
                    <i class="fas fa-save me-1"></i> Salvar Instrutor
                </button>
                <a asp-page="Index" class="btn btn-dk-secondary btn-lg px-4">
                    <i class="fas fa-arrow-left me-1"></i> Voltar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
