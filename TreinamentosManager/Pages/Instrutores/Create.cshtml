@page
@model TreinamentosManager.Pages.Instrutores.CreateModel
@{
    ViewData["Title"] = "Adicionar Instrutor";
}

<h1>Adicionar Instrutor</h1>

<h4>Instrutor</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Instrutor.Nome" class="control-label"></label>
                <input asp-for="Instrutor.Nome" class="form-control" />
                <span asp-validation-for="Instrutor.Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Instrutor.Email" class="control-label"></label>
                <input asp-for="Instrutor.Email" class="form-control" type="email" />
                <span asp-validation-for="Instrutor.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Adicionar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Voltar para Lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}