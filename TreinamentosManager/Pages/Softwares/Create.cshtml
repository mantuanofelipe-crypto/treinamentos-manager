@page
@model TreinamentosManager.Pages.Softwares.CreateModel
@{
    ViewData["Title"] = "Novo Software";
}

<div class="card shadow-sm">
    <div class="card-header-dk d-flex align-items-center gap-2">
        <i class="fas fa-plus-circle"></i>
        <h5 class="mb-0">Adicionar Software</h5>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Software.Nome" class="form-label form-label-dk"></label>
                    <input asp-for="Software.Nome" class="form-control" placeholder="Ex: AutoCAD, Revit" />
                    <span asp-validation-for="Software.Nome" class="text-danger small"></span>
                </div>
            </div>
            <div class="section-divider"></div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dk-primary btn-lg px-4">
                    <i class="fas fa-save me-1"></i> Salvar Software
                </button>
                <a asp-page="Index" class="btn btn-dk-secondary btn-lg px-4">
                    <i class="fas fa-arrow-left me-1"></i> Voltar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
