@page
@model TreinamentosManager.Pages.Turmas.IndexModel
@{
    ViewData["Title"] = "Turmas";
}

<div class="card shadow-sm mb-3">
    <div class="card-header-dk d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-chalkboard-teacher me-2"></i>Gerenciar Turmas</h5>
        <a asp-page="Create" class="btn btn-dk-primary btn-sm px-3">
            <i class="fas fa-plus me-1"></i> Nova Turma
        </a>
    </div>
    <div class="card-body pb-0">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">Todos os status</option>
                    <option value="Futura" selected="@(Model.FiltroStatus == "Futura")">Futura</option>
                    <option value="Em andamento" selected="@(Model.FiltroStatus == "Em andamento")">Em andamento</option>
                    <option value="Concluída" selected="@(Model.FiltroStatus == "Concluída")">Concluída</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="clienteId" class="form-select form-select-sm">
                    <option value="">Todos os clientes</option>
                    @foreach (var c in Model.Clientes)
                    {
                        <option value="@c.Id" selected="@(Model.FiltroClienteId == c.Id)">@c.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="instrutorId" class="form-select form-select-sm">
                    <option value="">Todos os instrutores</option>
                    @foreach (var i in Model.Instrutores)
                    {
                        <option value="@i.Id" selected="@(Model.FiltroInstrutorId == i.Id)">@i.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="modalidade" class="form-select form-select-sm">
                    <option value="">Todas as modalidades</option>
                    <option value="Presencial" selected="@(Model.FiltroModalidade == "Presencial")">Presencial</option>
                    <option value="Online" selected="@(Model.FiltroModalidade == "Online")">Online</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-dk-primary btn-sm w-100">
                    <i class="fas fa-filter"></i>
                </button>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Modalidade</th>
                        <th>ID Autodesk</th>
                        <th>Cliente</th>
                        <th>Software</th>
                        <th>Carga Horária</th>
                        <th>Dias da Semana</th>
                        <th>Início</th>
                        <th>Fim</th>
                        <th>Instrutor</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Turmas)
                    {
                        <tr>
                            <td>
                                @{
                                    var badgeClass = item.Status switch {
                                        "Concluída"    => "badge-concluida",
                                        "Em andamento" => "badge-andamento",
                                        _              => "badge-futura"
                                    };
                                    var icon = item.Status switch {
                                        "Concluída"    => "fa-check-circle",
                                        "Em andamento" => "fa-spinner",
                                        _              => "fa-calendar-alt"
                                    };
                                }
                                <span class="badge @badgeClass px-2 py-1">
                                    <i class="fas @icon me-1"></i>@item.Status
                                </span>
                            </td>
                            <td>
                                @if (item.Modalidade == "Online")
                                {
                                    <span class="badge bg-info text-dark"><i class="fas fa-wifi me-1"></i>Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="fas fa-map-marker-alt me-1"></i>Presencial</span>
                                }
                            </td>
                            <td>@Html.DisplayFor(m => item.IdAutodesk)</td>
                            <td>@(item.Cliente?.Nome ?? "—")</td>
                            <td>@(item.Software?.Nome ?? "—")</td>
                            <td>@Html.DisplayFor(m => item.CargaHoraria)h</td>
                            <td>@Html.DisplayFor(m => item.DiasDaSemana)</td>
                            <td>@item.Inicio.ToString("dd/MM/yyyy")</td>
                            <td>@item.Fim.ToString("dd/MM/yyyy")</td>
                            <td>@(item.Instrutor?.Nome ?? "—")</td>
                            <td class="text-center">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Detalhes">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Excluir">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Turmas.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>Nenhuma turma encontrada.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
